# heard-sheep environment variables

# Public base path for Next.js routes and client-side API requests.
# Default code path is /sheep.
NEXT_PUBLIC_BASE_PATH=/sheep

# AI provider: deepseek | mimo | mock
AI_PROVIDER=deepseek
AI_ALLOW_MOCK_FALLBACK=true

# DeepSeek V4 OpenAI-compatible Chat Completions
# Recommended default: deepseek-v4-flash
# Higher quality option: deepseek-v4-pro
# Do not commit real API keys. Keep real values in .env.local only.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=60000

# Optional Xiaomi MiMo OpenAI-compatible Chat Completions
# Text analysis can still be switched to MiMo with AI_PROVIDER=mimo,
# but the recommended default text analysis provider is DeepSeek.
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=MiMo-V2.5-Pro
MIMO_TIMEOUT_MS=60000

# Xiaomi MiMo multimodal provider
# Used by image understanding and audio understanding.
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1
XIAOMI_TIMEOUT_MS=60000

# Xiaomi MiMo Image Understanding
# Upload image -> extract text -> user confirms -> DeepSeek task planning.
VISION_PROVIDER=xiaomi-image
VISION_ALLOW_TEXT_FALLBACK=true
XIAOMI_IMAGE_MODEL=mimo-v2.5

# ASR provider: mock | xiaomi-audio | openai-compatible | openai | whisper
# Browser Web Speech API is used client-side when available.
ASR_PROVIDER=xiaomi-audio
ASR_ALLOW_MOCK_FALLBACK=true

# Xiaomi MiMo Audio Understanding
# Used by /api/transcribe when ASR_PROVIDER=xiaomi-audio.
XIAOMI_AUDIO_MODEL=mimo-v2.5
# input_audio is the default OpenAI-compatible multimodal block.
# If a provider needs data URL style audio blocks, try audio_url.
XIAOMI_AUDIO_INPUT_MODE=input_audio

# OpenAI-compatible audio transcription endpoint.
# Keep real keys in .env.local only.
ASR_API_KEY=
ASR_BASE_URL=https://api.openai.com/v1
ASR_MODEL=whisper-1
ASR_LANGUAGE=zh
ASR_TIMEOUT_MS=60000
# Optional ASR prompt/context
# ASR_PROMPT=
