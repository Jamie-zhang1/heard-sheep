# ============================================
# 听到了咩 — 环境变量配置
# ============================================

# ---------- AI 分析 Provider ----------
# 可选值: "mimo" (默认) | "mock"
AI_PROVIDER=mimo

# MiMo API 配置（使用 mimo provider 时必填）
MIMO_API_KEY=your-mimo-api-key-here
# MiMo 模型名称（可选，默认 mimo-chat）
MIMO_MODEL=mimo-chat
# MiMo API 基础 URL（可选，默认 https://api.xiaomimimo.com/v1）
# MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# MiMo 请求超时毫秒（可选，默认 30000）
# MIMO_TIMEOUT_MS=30000

# 当 AI_PROVIDER=mimo 但 MIMO_API_KEY 未设置时，是否回退到 mock
# 设为 "false" 可强制要求配置真实 API Key
# AI_ALLOW_MOCK_FALLBACK=true

# ---------- ASR 语音转写 Provider ----------
# 可选值: "mock" (默认) | "browser"
# "browser" = 使用浏览器 Web Speech API 实时转写（仅浏览器端生效）
# 服务端 transcribe 路由始终使用 server-side provider
ASR_PROVIDER=browser

# 当 ASR_PROVIDER 非 mock 且转写失败时，是否回退到 mock
# ASR_ALLOW_MOCK_FALLBACK=true

# ---------- 客户端环境变量 ----------
# Next.js 客户端环境变量需要以 NEXT_PUBLIC_ 开头
# 目前无客户端环境变量需求
